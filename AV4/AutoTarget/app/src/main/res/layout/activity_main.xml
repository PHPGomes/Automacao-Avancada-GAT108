<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Área do jogo -->

    <com.example.autotarget.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layoutBotoes"/>

    <!-- Painel inferior -->

    <LinearLayout
        android:id="@+id/layoutBotoes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#F5F5F5">

        <!-- Primeira linha -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnIniciar"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Iniciar"/>

            <Space
                android:layout_width="6dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnAdicionarEsquerda"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="+ Canhão Esq"/>

            <Space
                android:layout_width="6dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnAdicionarDireita"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="+ Canhão Dir"/>

        </LinearLayout>

        <!-- Segunda linha -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Login"/>

            <Space
                android:layout_width="6dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnRanking"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Ranking"/>

            <Space
                android:layout_width="6dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnHistorico"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Histórico"/>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>